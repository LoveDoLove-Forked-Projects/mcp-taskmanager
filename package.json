{
	"name": "@kazuph/mcp-taskmanager",
	"version": "1.1.0",
	"description": "Model Context Protocol server for Task Management",
	"author": "kazuph (https://x.com/kazuph)",
	"main": "dist/index.js",
	"type": "module",
	"bin": {
		"mcp-taskmanager": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc && shx chmod +x dist/*.js",
		"prepare": "npm run build",
		"watch": "tsc --watch",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kazuph/mcp-taskmanager.git"
	},
	"keywords": [
		"taskmanager",
		"mcp",
		"claude"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.20.0",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"shx": "^0.3.4",
		"typescript": "^5.6.0",
		"vitest": "^3.2.6"
	}
}
